class AntiProcastinationApp {
  constructor() {
    this.tasks = [];
    this.currentTask = null;
    this.mode = null;

    this.container = document.querySelector(".task-list");
    this.popup = document.querySelector(".popup-overlay");
    this.reasonInput = document.querySelector("#ReasonPopupInput");
    this.saveReasonBtn = document.querySelector("#saveReason");
    this.cancelBtn = document.querySelector("#cancelPopup");

    this.saveReasonBtn.addEventListener("click", () => this.handlePopupSave());
    this.cancelBtn.addEventListener("click", () => this.closePopup());

    document.addEventListener("click", () => {
      document.querySelectorAll(".dropdown-menu").forEach((m) => {
        m.classList.remove("show");
      });
    });
  }

  init() {
    const data = localStorage.getItem("tasks");
    this.tasks = data ? JSON.parse(data) : [];

    // reset running timers
    this.tasks.forEach((task) => {
      if (task.status === "in-progress") {
        task.status = "paused";
        task.intervalID = null;
      }
    });

    this.renderTasks();
    this.inputTask();
  }

  inputTask() {
    const input = document.querySelector(".task-input input");
    const btn = document.querySelector(".add-btn");

    btn.addEventListener("click", () => {
      const value = input.value.trim();
      if (value.length < 3) return alert("Invalid Input");

      this.addTask(value);
      input.value = "";
    });
  }

  addTask(task) {
    if (this.tasks.length >= 5) {
      return alert("Max 5 tasks allowed");
    }

    this.tasks.push({
      id: Date.now(),
      task,
      status: "pending",
      timeLeft: 300,
      intervalID: null,
      reason: null,
    });

    this.save();
    this.renderTasks();
  }

  renderTasks() {
    this.container.innerHTML = "";

    this.tasks.forEach((task) => {
      const card = document.createElement("div");
      card.className = "task-card";

      // TEXT
      const text = document.createElement("span");
      text.textContent = task.task;

      if (task.status === "done" || task.status === "skipped") {
        text.classList.add("completed");
      }

      // TIMER
      const timer = document.createElement("div");
      timer.className = "timer";
      timer.dataset.id = task.id;

      if (task.status === "in-progress") {
        timer.textContent = this.formatTime(task.timeLeft);
      } else {
        timer.style.display = "none";
      }

      // BUTTONS
      const btns = document.createElement("div");

      if (task.status === "skipped") {
        btns.textContent = "Skipped";
      } else if (task.status === "done") {
        btns.textContent = "Completed";
      } else {
        btns.append(
          this.createStartBtn(task),
          this.createDoneBtn(task),
          this.createMenu(task)
        );
      }

      card.append(text, timer, btns);
      this.container.appendChild(card);
    });
  }

  createStartBtn(task) {
    const btn = document.createElement("button");

    btn.textContent =
      task.status === "in-progress"
        ? "Pause"
        : task.status === "paused"
        ? "Resume"
        : "Start";

    btn.onclick = () => this.handleTimer(task);

    return btn;
  }

  createDoneBtn(task) {
    const btn = document.createElement("button");
    btn.textContent = "Done";

    btn.onclick = () => {
      clearInterval(task.intervalID);
      task.status = "done";
      task.intervalID = null;

      this.save();
      this.renderTasks();
    };

    return btn;
  }

  createMenu(task) {
    const wrapper = document.createElement("div");

    const btn = document.createElement("button");
    btn.textContent = "⋮";

    const menu = document.createElement("div");
    menu.className = "dropdown-menu";

    menu.innerHTML = `
      <button class="skip">Skip</button>
      <button class="edit">Edit</button>
      <button class="delete">Delete</button>
    `;

    btn.onclick = (e) => {
      e.stopPropagation();
      menu.classList.toggle("show");
    };

    menu.querySelector(".skip").onclick = () =>
      this.openPopup(task, "skip");

    menu.querySelector(".edit").onclick = () =>
      this.openPopup(task, "edit");

    menu.querySelector(".delete").onclick = () => {
      this.tasks = this.tasks.filter((t) => t.id !== task.id);
      this.save();
      this.renderTasks();
    };

    wrapper.append(btn, menu);
    return wrapper;
  }

  handleTimer(task) {
    // pause
    if (task.intervalID) {
      clearInterval(task.intervalID);
      task.intervalID = null;
      task.status = "paused";
      this.save();
      this.renderTasks();
      return;
    }

    // stop others
    this.tasks.forEach((t) => {
      if (t.intervalID) {
        clearInterval(t.intervalID);
        t.intervalID = null;
        t.status = "paused";
      }
    });

    task.status = "in-progress";

    task.intervalID = setInterval(() => {
      task.timeLeft--;

      if (task.timeLeft <= 0) {
        clearInterval(task.intervalID);
        task.intervalID = null;
        task.status = "done";

        this.save();
        this.renderTasks();
        return;
      }

      this.updateTimer(task);
    }, 1000);

    this.save();
    this.renderTasks();
  }

  updateTimer(task) {
    const el = document.querySelector(
      `.timer[data-id="${task.id}"]`
    );
    if (el) el.textContent = this.formatTime(task.timeLeft);
  }

  openPopup(task, mode) {
    this.popup.style.display = "flex";
    this.currentTask = task;
    this.mode = mode;

    if (mode === "skip") {
      this.reasonInput.value = "";
      this.reasonInput.placeholder = "Why skip?";
    } else {
      this.reasonInput.value = task.task;
      this.reasonInput.placeholder = "Edit task";
    }
  }

  handlePopupSave() {
    const value = this.reasonInput.value.trim();
    if (!this.currentTask) return;

    if (this.mode === "skip") {
      this.currentTask.status = "skipped";
      this.currentTask.reason = value || "no reason";
      clearInterval(this.currentTask.intervalID);
    }

    if (this.mode === "edit") {
      if (value.length < 3) return alert("Too short");
      this.currentTask.task = value;
    }

    this.save();
    this.closePopup();
    this.renderTasks();
  }

  closePopup() {
    this.popup.style.display = "none";
    this.currentTask = null;
  }

  save() {
    localStorage.setItem("tasks", JSON.stringify(this.tasks));
  }

  formatTime(sec) {
    const m = Math.floor(sec / 60);
    const s = sec % 60;
    return `${String(m).padStart(2, "0")}:${String(s).padStart(2, "0")}`;
  }
}

const app = new AntiProcastinationApp();
app.init();